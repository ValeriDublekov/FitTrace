{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Admin user who can manage exercises",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "Global or custom exercise definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "loadType": { "type": "string", "enum": ["WEIGHT_REPS", "LEVEL_REPS", "CARDIO"] },
        "thumbnailUrl": { "type": "string" },
        "defaultNotes": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "userId": { "type": "string", "description": "Owner of the custom exercise if applicable" },
        "isCustom": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "loadType", "createdAt"]
    },
    "Workout": {
      "title": "Workout",
      "description": "A user workout session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": {
            "$ref": "#/entities/WorkoutExercise"
          }
        },
        "startedAt": { "type": "string", "format": "date-time" },
        "durationSeconds": { "type": "number" }
      },
      "required": ["userId", "date", "exercises"]
    },
    "WorkoutExercise": {
      "title": "WorkoutExercise",
      "description": "An exercise within a workout session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "exerciseId": { "type": "string" },
        "exerciseName": { "type": "string" },
        "sessionNotes": { "type": "string" },
        "sets": {
          "type": "array",
          "items": {
            "$ref": "#/entities/ExerciseSet"
          }
        },
        "startedAt": { "type": "string", "format": "date-time" },
        "durationSeconds": { "type": "number" }
      },
      "required": ["id", "exerciseId", "exerciseName", "sets"]
    },
    "ExerciseSet": {
      "title": "ExerciseSet",
      "description": "A single set of an exercise",
      "type": "object",
      "properties": {
        "setIndex": { "type": "number" },
        "weight": { "type": "number" },
        "level": { "type": "number" },
        "reps": { "type": "number" },
        "duration": { "type": "number" }
      },
      "required": ["setIndex"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "isPublic": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["isPublic", "updatedAt", "updatedBy"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "Individual user preferences",
      "type": "object",
      "properties": {
        "fontSize": { "type": "string", "enum": ["normal", "large", "xlarge"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fontSize", "updatedAt"]
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global application settings"
    },
    "/admins/{userId}": {
      "schema": "Admin",
      "description": "List of authorized admins"
    },
    "/exercises/{exerciseId}": {
      "schema": "Exercise",
      "description": "Global exercise database"
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "User workout history"
    },
    "/users/{userId}/settings/display": {
      "schema": "UserSettings",
      "description": "User specific display settings"
    }
  }
}
