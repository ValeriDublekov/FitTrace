rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validations ---

    function isValidAdmin(admin) {
      return admin.keys().hasAll(['email', 'createdAt']) 
        && admin.keys().size() == 2
        && admin.email is string
        && admin.createdAt is timestamp;
    }

    function isValidExercise(exercise) {
      // Mandatory fields for both create and update
      let mandatoryFields = ['name', 'category', 'loadType', 'isCustom'];
      // Optional fields that might be present
      let optionalFields = ['thumbnailUrl', 'defaultNotes', 'description', 'updatedAt', 'userId', 'url', 'id', 'createdAt', 'affectedPart'];
      
      return exercise.keys().hasAll(mandatoryFields)
        && exercise.keys().size() <= mandatoryFields.size() + optionalFields.size()
        && exercise.name is string && exercise.name.size() <= 200
        && exercise.category is string && exercise.category.size() <= 100
        && exercise.loadType in ['WEIGHT_REPS', 'LEVEL_REPS', 'CARDIO']
        && exercise.isCustom is bool
        && (!('thumbnailUrl' in exercise) || exercise.thumbnailUrl == null || exercise.thumbnailUrl is string)
        && (!('defaultNotes' in exercise) || exercise.defaultNotes == null || exercise.defaultNotes is string)
        && (!('description' in exercise) || exercise.description == null || (exercise.description is string && exercise.description.size() <= 10000))
        && (!('url' in exercise) || exercise.url == null || exercise.url is string)
        && (!('userId' in exercise) || exercise.userId == null || exercise.userId is string)
        && (!('id' in exercise) || exercise.id == null || exercise.id is string)
        && (!('affectedPart' in exercise) || exercise.affectedPart == null || (exercise.affectedPart is string && exercise.affectedPart.size() <= 200))
        && (!('createdAt' in exercise) || exercise.createdAt is timestamp)
        && (resource == null || !('createdAt' in resource.data) || !('createdAt' in exercise) || exercise.createdAt == resource.data.createdAt);
    }

    function isValidExerciseSet(set) {
      return set is map
        && set.keys().hasAll(['setIndex'])
        && (
          ( ('setIndex' in set ? 1 : 0) +
            ('weight' in set ? 1 : 0) +
            ('level' in set ? 1 : 0) +
            ('reps' in set ? 1 : 0) +
            ('duration' in set ? 1 : 0) +
            ('isCompleted' in set ? 1 : 0) ) == set.keys().size()
        )
        && set.setIndex is int
        && (!('weight' in set) || set.weight == null || set.weight is number)
        && (!('level' in set) || set.level == null || set.level is int)
        && (!('reps' in set) || set.reps == null || set.reps is int)
        && (!('duration' in set) || set.duration == null || set.duration is int)
        && (!('isCompleted' in set) || set.isCompleted == null || set.isCompleted is bool);
    }

    function isValidWorkoutExercise(exercise) {
      return exercise is map
        && exercise.keys().hasAll(['id', 'exerciseId', 'exerciseName', 'sets'])
        && (
          ( ('id' in exercise ? 1 : 0) +
            ('exerciseId' in exercise ? 1 : 0) +
            ('exerciseName' in exercise ? 1 : 0) +
            ('sessionNotes' in exercise ? 1 : 0) +
            ('sets' in exercise ? 1 : 0) +
            ('startedAt' in exercise ? 1 : 0) +
            ('durationSeconds' in exercise ? 1 : 0) +
            ('affectedPart' in exercise ? 1 : 0) +
            ('supersetGroupId' in exercise ? 1 : 0) ) == exercise.keys().size()
        )
        && exercise.id is string
        && exercise.exerciseId is string
        && exercise.exerciseName is string && exercise.exerciseName.size() <= 200
        && (!('sessionNotes' in exercise) || exercise.sessionNotes == null || exercise.sessionNotes is string)
        && (!('startedAt' in exercise) || exercise.startedAt is timestamp)
        && (!('durationSeconds' in exercise) || exercise.durationSeconds == null || exercise.durationSeconds is int)
        && (!('affectedPart' in exercise) || exercise.affectedPart == null || exercise.affectedPart is string)
        && (!('supersetGroupId' in exercise) || exercise.supersetGroupId == null || exercise.supersetGroupId is string)
        && exercise.sets is list
        && exercise.sets.size() <= 50
        && (exercise.sets.size() == 0 || isValidExerciseSet(exercise.sets[0]));
    }

    function isValidWorkout(workout) {
      return workout.keys().hasAll(['userId', 'date', 'exercises'])
        && (
          ( ('userId' in workout ? 1 : 0) +
            ('date' in workout ? 1 : 0) +
            ('exercises' in workout ? 1 : 0) +
            ('notes' in workout ? 1 : 0) +
            ('startedAt' in workout ? 1 : 0) +
            ('durationSeconds' in workout ? 1 : 0) +
            ('updatedAt' in workout ? 1 : 0) ) == workout.keys().size()
        )
        && workout.userId == request.auth.uid
        && workout.date is timestamp
        && (!('notes' in workout) || workout.notes == null || (workout.notes is string && workout.notes.size() <= 10000))
        && (!('startedAt' in workout) || workout.startedAt is timestamp)
        && (!('durationSeconds' in workout) || workout.durationSeconds == null || workout.durationSeconds is int)
        && (!('updatedAt' in workout) || workout.updatedAt is timestamp)
        && workout.exercises is list
        && workout.exercises.size() <= 30
        && (workout.exercises.size() == 0 || isValidWorkoutExercise(workout.exercises[0]));
    }

    function isValidWorkoutTemplate(template) {
      return template.keys().hasAll(['userId', 'name', 'exerciseIds', 'createdAt'])
        && (
          ( ('userId' in template ? 1 : 0) +
            ('name' in template ? 1 : 0) +
            ('exerciseIds' in template ? 1 : 0) +
            ('createdAt' in template ? 1 : 0) ) == template.keys().size()
        )
        && template.userId == request.auth.uid
        && template.name is string && template.name.size() <= 200
        && template.exerciseIds is list
        && template.exerciseIds.size() <= 50
        && (template.exerciseIds.size() == 0 || template.exerciseIds[0] is string)
        && template.createdAt is timestamp;
    }

    function isValidSettings(settings) {
      return settings.keys().hasAll(['isPublic', 'updatedAt', 'updatedBy'])
        && settings.keys().size() == 3
        && settings.isPublic is bool
        && settings.updatedAt is timestamp
        && settings.updatedBy == request.auth.uid;
    }

    function isValidUserSettings(settings) {
      return settings.keys().hasAll(['updatedAt'])
        && settings.updatedAt is timestamp
        // Validate fontSize if exists
        && (!('fontSize' in settings) || settings.fontSize in ['normal', 'large', 'xlarge'])
        // Validate language if exists
        && (!('language' in settings) || settings.language in ['bg', 'en'])
        // Validate notificationSound if exists
        && (!('notificationSound' in settings) || (settings.notificationSound is string && settings.notificationSound.size() <= 200))
        // Validate isNotificationsEnabled if exists
        && (!('isNotificationsEnabled' in settings) || settings.isNotificationsEnabled is bool)
        // Ensure only allowed fields are present (no other keys)
        && (
          ( ('fontSize' in settings ? 1 : 0) +
            ('language' in settings ? 1 : 0) +
            ('notificationSound' in settings ? 1 : 0) +
            ('isNotificationsEnabled' in settings ? 1 : 0) +
            ('updatedAt' in settings ? 1 : 0) ) == settings.keys().size()
        );
    }

    // --- Matches ---

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /admins/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; 
    }

    match /exercises/{exerciseId} {
      allow read: if isSignedIn() && (
        resource.data.get('isCustom', false) == false || 
        resource.data.get('userId', '') == request.auth.uid
      );
      allow create: if isSignedIn() 
        && isValidExercise(request.resource.data)
        && (
          (isAdmin() && request.resource.data.isCustom == false) || 
          (request.resource.data.isCustom == true && request.resource.data.userId == request.auth.uid)
        );
      allow update: if isSignedIn() 
        && isValidExercise(request.resource.data)
        && (
          (isAdmin() && request.resource.data.isCustom == false) || 
          (resource.data.get('isCustom', false) == true && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && request.resource.data.isCustom == true)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'category', 'loadType', 'thumbnailUrl', 'defaultNotes', 'description', 'url', 'updatedAt', 'userId', 'isCustom', 'affectedPart'])
        && request.resource.data.updatedAt == request.time;
      allow delete: if isAdmin() || (resource.data.get('userId', '') == request.auth.uid);
    }

    match /workouts/{workoutId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWorkout(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidWorkout(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }

    match /workout_templates/{templateId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWorkoutTemplate(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidWorkoutTemplate(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }

    match /users/{userId}/settings/display {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) 
        && isValidUserSettings(request.resource.data)
        && request.resource.data.updatedAt == request.time;
    }
  }
}
