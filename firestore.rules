rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'v.dublekov@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validations ---

    function isValidAdmin(admin) {
      return admin.keys().hasAll(['email', 'createdAt']) 
        && admin.keys().size() == 2
        && admin.email is string
        && admin.createdAt is timestamp;
    }

    function isValidExercise(exercise) {
      // Mandatory fields for both create and update
      let mandatoryFields = ['name', 'category', 'loadType', 'createdAt'];
      // Optional fields that might be present
      let optionalFields = ['thumbnailUrl', 'defaultNotes', 'updatedAt', 'userId', 'isCustom'];
      
      return exercise.keys().hasAll(mandatoryFields)
        && exercise.keys().size() <= mandatoryFields.size() + optionalFields.size()
        && exercise.name is string && exercise.name.size() <= 200
        && exercise.category is string && exercise.category.size() <= 100
        && exercise.loadType in ['WEIGHT_REPS', 'LEVEL_REPS', 'CARDIO']
        && (exercise.get('thumbnailUrl', '') is string)
        && (exercise.get('defaultNotes', '') is string)
        && (exercise.get('userId', '') == '' || exercise.userId is string)
        && (exercise.get('isCustom', false) is bool)
        && exercise.createdAt == (resource == null ? request.time : resource.data.createdAt);
    }

    function isValidWorkout(workout) {
      return workout.keys().hasAll(['userId', 'date', 'exercises'])
        && workout.userId == request.auth.uid
        && workout.date is timestamp
        && workout.exercises is list
        && workout.exercises.size() <= 30; // Limit number of exercises in a workout
    }

    function isValidSettings(settings) {
      return settings.keys().hasAll(['isPublic', 'updatedAt', 'updatedBy'])
        && settings.keys().size() == 3
        && settings.isPublic is bool
        && settings.updatedAt is timestamp
        && settings.updatedBy == request.auth.uid;
    }

    function isValidUserSettings(settings) {
      return settings.keys().hasAll(['fontSize', 'updatedAt'])
        && settings.keys().size() == 2
        && settings.fontSize in ['normal', 'large', 'xlarge']
        && settings.updatedAt is timestamp;
    }

    // --- Matches ---

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /admins/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; 
    }

    match /exercises/{exerciseId} {
      allow read: if isSignedIn() && (
        !('userId' in resource.data) || resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() 
        && isValidExercise(request.resource.data)
        && (
          isAdmin() || 
          (request.resource.data.userId == request.auth.uid && request.resource.data.isCustom == true)
        );
      allow update: if isSignedIn() 
        && isValidExercise(request.resource.data)
        && (
          isAdmin() || 
          (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'category', 'loadType', 'thumbnailUrl', 'defaultNotes', 'updatedAt', 'userId', 'isCustom'])
        && request.resource.data.updatedAt == request.time;
      allow delete: if isAdmin() || (resource.data.userId == request.auth.uid);
    }

    match /workouts/{workoutId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWorkout(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidWorkout(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }

    match /users/{userId}/settings/display {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) 
        && isValidUserSettings(request.resource.data)
        && request.resource.data.updatedAt == request.time;
    }
  }
}
